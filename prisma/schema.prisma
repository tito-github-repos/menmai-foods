generator client {
  provider = "prisma-client-js"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "mysql"
  url      = env("DATABASE_URL")
}

model Admin {
  id               Int       @id @default(autoincrement())
  username         String    @unique
  email            String    @unique
  password         String
  resetToken       String?   @unique
  resetTokenExpiry DateTime?
  createdAt        DateTime  @default(now())
}

model BulkOrderItem {
  id                 Int              @id @default(autoincrement())
  bulkOrderId Int
  productId          Int

  productName        String
  quantity           Int
  unitPrice          Float?
  totalPrice         Float?

  BulkOrder          BulkOrder @relation(fields: [bulkOrderId], references: [id], onDelete: Cascade)
  Product            Product          @relation(fields: [productId], references: [id], onDelete: Cascade)

  @@index([bulkOrderId])
  @@index([productId])
}

model BulkOrder {
  id              Int   @id @default(autoincrement())
  orderRef        String          @unique
  customerId      Int?    

  customerName    String
  phone           String
  email           String?

  deliveryDate    DateTime
  deliveryTime    String
  occasion        String
  deliveryAddress String
  pincode         String

  subtotal        Float           @default(0)
  deliveryCharge  Float           @default(0)
  estimatedTotal  Float           @default(0)

  status          BulkOrder_status@default(NEW)
  source          BulkOrderSource @default(CUSTOMER_FORM)
  notes           String?         @db.Text

  createdAt       DateTime         @default(now())
  updatedAt       DateTime         @updatedAt
 
  Customer        Customer?        @relation(fields: [customerId], references: [id], onDelete: SetNull)
  items           BulkOrderItem[]

  @@index([customerId])
  @@index([deliveryDate])
  @@index([status])
}


model CartItem {
  id         Int      @id @default(autoincrement())
  customerId Int
  productId  Int
  quantity   Int
  createdAt  DateTime @default(now())
  updatedAt  DateTime
  Customer   Customer @relation(fields: [customerId], references: [id], onDelete: Cascade)
  Product    Product  @relation(fields: [productId], references: [id], onDelete: Cascade)

  @@unique([customerId, productId])
  @@index([productId], map: "CartItem_productId_fkey")
}

model Customer {
  id              Int               @id @default(autoincrement())
  fullName        String
  phone           String            @unique
  email           String?
  isPhoneVerified Boolean           @default(false)
  createdAt       DateTime          @default(now())
  updatedAt       DateTime
  CartItem        CartItem[]
  CustomerAddress CustomerAddress[]
  Order           Order[]
  BulkOrder       BulkOrder[]
  Review          Review[]
  OTPVerification OTPVerification[]

  BroadcastRecipient BroadcastRecipient[]
}

model CustomerAddress {
  id          Int      @id @default(autoincrement())
  customerId  Int
  addressType String?
  fullAddress String
  landmark    String?
  area        String?
  city        String
  pincode     String
  latitude    Float?
  longitude   Float?
  isDefault   Boolean  @default(false)
  createdAt   DateTime @default(now())
  updatedAt   DateTime
  Customer    Customer @relation(fields: [customerId], references: [id], onDelete: Cascade)
  Order       Order[]

  @@index([customerId], map: "CustomerAddress_customerId_fkey")
}

model GoogleSheetSyncLog {
  id         Int      @id @default(autoincrement())
  orderId    Int
  syncStatus String
  createdAt  DateTime @default(now())
  Order      Order    @relation(fields: [orderId], references: [id], onDelete: Cascade)

  @@index([orderId], map: "GoogleSheetSyncLog_orderId_fkey")
}

model OTPVerification {
  id              Int       @id @default(autoincrement())

  phone           String    @unique
  otpCode         String
  verified        Boolean   @default(false)

  resendCount     Int       @default(0)
  otpWindowStart  DateTime?
  lastSentAt      DateTime?
  expiresAt       DateTime

  customerId      Int?
  Customer        Customer? @relation(fields: [customerId], references: [id], onDelete: Cascade)

  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt

  @@index([phone])
  @@index([customerId])
}

model Order {
  id                 Int                  @id @default(autoincrement())
  orderNumber        String               @unique
  customerId         Int
  addressId          Int
  subtotal           Float
  deliveryCharge     Float                @default(0)
  totalAmount        Float
  cartSnapshot       Json? 
  paymentStatus      Order_paymentStatus  @default(PENDING)
  orderStatus        Order_orderStatus    @default(PENDING)
  orderExpiresAt     DateTime?
  orderedAt          DateTime             @default(now())
  createdAt          DateTime             @default(now())
  updatedAt          DateTime
  GoogleSheetSyncLog GoogleSheetSyncLog[]
  CustomerAddress    CustomerAddress      @relation(fields: [addressId], references: [id], onDelete: Cascade)
  Customer           Customer             @relation(fields: [customerId], references: [id], onDelete: Cascade)
  OrderItem          OrderItem[]
  Payment            Payment?
  WhatsAppLog        WhatsAppLog[]
  ReviewRequest      ReviewRequest?
  Review             Review[]
  @@index([addressId], map: "Order_addressId_fkey")
  @@index([customerId], map: "Order_customerId_fkey")
}

model OrderItem {
  id          Int     @id @default(autoincrement())
  orderId     Int
  productId   Int
  productName String
  quantity    Int
  unitPrice   Float
  totalPrice  Float
  Order       Order   @relation(fields: [orderId], references: [id], onDelete: Cascade)
  Product     Product @relation(fields: [productId], references: [id], onDelete: Cascade)

  @@index([orderId], map: "OrderItem_orderId_fkey")
  @@index([productId], map: "OrderItem_productId_fkey")
}

model Payment {
  id                Int                   @id @default(autoincrement())
  orderId           Int                   @unique
  razorpayPaymentId String?
  amount            Float
  paymentStatus     Payment_paymentStatus @default(PENDING)
  createdAt         DateTime              @default(now())
  updatedAt         DateTime              @updatedAt
  razorpayOrderId   String?
  razorpaySignature String?
  Order             Order                 @relation(fields: [orderId], references: [id], onDelete: Cascade)
}


enum Payment_paymentStatus {
  PENDING
  PAID
  FAILED
  REFUNDED
}

enum Order_paymentStatus {
  PENDING
  PAID
  FAILED
  REFUNDED
}

enum BulkOrder_status {
  NEW
  ACCEPTED
  IN_DISCUSSION
  REJECTED
  DELIVERED
}

enum BulkOrderSource {
  CUSTOMER_FORM
  ADMIN_MANUAL
}

enum Order_orderStatus {
  PENDING
  CONFIRMED
  PREPARING
  SHIPPED
  DELIVERED
  CANCELLED
  EXPIRED
  ABANDONED
}

model Product {
  id            Int             @id @default(autoincrement())
  name          String
  slug          String          @unique
  price         Float
  mrp           Float?
  netWeight     String?
  pieces        Int?
  imageUrl      String?
  stockQuantity Int             @default(0)
  isActive      Boolean         @default(true)
  createdAt     DateTime        @default(now())
  updatedAt     DateTime        @updatedAt
  images        ProductImage[]
  BulkOrderItem BulkOrderItem[]
  CartItem      CartItem[]
  OrderItem     OrderItem[]
  bulkPricePerPiece Float?
  Review            Review[]
}

model ProductImage {
  id        Int     @id @default(autoincrement())
  productId Int
  imageUrl  String
  altText   String?
  sortOrder Int     @default(0)

  Product Product @relation(fields: [productId], references: [id], onDelete: Cascade)

  @@index([productId])
}

model WhatsAppLog {
  id        Int      @id @default(autoincrement())
  orderId   Int?
  messageId String?
  phone     String?
  direction String
  eventType String
  status    String
  payload   Json?
  createdAt DateTime @default(now())

  Order Order? @relation(fields: [orderId], references: [id], onDelete: Cascade)

  @@index([orderId])
  @@index([messageId])
  @@index([phone])
}

model ReviewRequest {
  id          Int       @id @default(autoincrement())
  orderId     Int       @unique
  token       String?   @unique
  scheduledAt DateTime
  sentAt      DateTime?
  status      String    @default("SCHEDULED")
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  Order Order @relation(fields: [orderId], references: [id], onDelete: Cascade)
}

model Review {
  id         Int      @id @default(autoincrement())
  orderId    Int
  productId  Int
  customerId Int
  rating     Int
  comment    String?  @db.Text
  isApproved Boolean  @default(true)
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt
  Customer   Customer @relation(fields: [customerId], references: [id], onDelete: Cascade)
  Order      Order    @relation(fields: [orderId], references: [id], onDelete: Cascade)
  Product    Product  @relation(fields: [productId], references: [id], onDelete: Cascade)

  @@index([customerId])
  @@index([orderId])
  @@index([productId])
}

model WebhookLog {
  id        Int      @id @default(autoincrement())
  eventId   String   @unique
  createdAt DateTime @default(now())
}


model DeliveryPincode {
  pincode  String  @id
  isActive Boolean @default(true)
}

model Broadcast {
  id            Int             @id @default(autoincrement())

  message       String          @db.Text
  imageUrl      String?

  status        BroadcastStatus @default(SENDING)

  totalCount    Int             @default(0)
  successCount  Int             @default(0)
  failedCount   Int             @default(0)

  scheduledAt   DateTime?
  completedAt   DateTime?

  createdAt     DateTime        @default(now())
  updatedAt     DateTime        @updatedAt

  recipients    BroadcastRecipient[]
}

model BroadcastRecipient {
  id            Int                        @id @default(autoincrement())

  broadcastId   Int
  customerId    Int

  phone         String
  messageId     String?

  status        BroadcastRecipientStatus   @default(PENDING)

  errorMessage  String?

  createdAt     DateTime                   @default(now())
  updatedAt     DateTime                   @updatedAt

  sentAt        DateTime?

  Broadcast     Broadcast @relation(fields: [broadcastId], references: [id], onDelete: Cascade)
  Customer      Customer  @relation(fields: [customerId], references: [id], onDelete: Cascade)

  @@index([broadcastId])
  @@index([customerId])
  @@index([phone])
}

enum BroadcastStatus {
  DRAFT
  SENDING
  COMPLETED
  FAILED
}

enum BroadcastRecipientStatus {
  PENDING
  SENT
  FAILED
}